{
  "expo": {
    "name": "Vocabularify",
    "slug": "vocabularify",
    "version": "1.2.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "vocabularify",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F5F1",
      "dark": {
        "image": "./assets/images/splash.png",
        "backgroundColor": "#0E0E10"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.huseyn0w.vocabularify",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.huseyn0w.vocabularify",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#F7F5F1"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "b5aed355-c97a-41ad-a673-114a0a07f2f0"
      }
    },
    "owner": "huseyn0w"
  }
}
